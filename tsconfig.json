{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@transitsoftservices/shared": [
        "./vendor/shared/index.ts"
      ],
      "@transitsoftservices/shared/*": [
        "./vendor/shared/*"
      ],
      "@transitsoftservices/skins": [
        "./vendor/skins/index.ts"
      ],
      "@transitsoftservices/skins/*": [
        "./vendor/skins/*"
      ],
      "@transitsoftservices/payments": [
        "./vendor/payments/index.ts"
      ],
      "@transitsoftservices/payments/*": [
        "./vendor/payments/*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
