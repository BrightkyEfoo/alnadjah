# alnadjah — variables d'environnement
#
# NEXT_PUBLIC_API_URL : base de l'API du tenant (avec /api/v1). Bakée au build
# (build-arg) et lisible au runtime. Si absente, le client dérive l'API depuis
# le hostname (<slug>.<base> -> api.<slug>.<base>).
#
# Exemple prod : https://api.alnadjah.transitsoftservices.com/api/v1
# Exemple local pointant sur un tenant distant : idem au-dessus.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
